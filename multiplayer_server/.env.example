# Base URL of the deployed Django backend (Vercel). Used to build the game-data
# endpoints the server fetches round data from (see src/gameEndpoints.js).
API_BASE_URL=https://<your-backend-project>.vercel.app

# Comma-separated allowed browser origins for Socket.IO / CORS (your deployed frontend).
CORS_ORIGINS=https://nba-trivia-minigames.online,http://localhost:5173

# Port to listen on. Most hosts inject this automatically; 4000 is the local default.
PORT=4000

# Optional: enable the Socket.IO Redis adapter for multi-instance broadcasting.
# REDIS_URL=rediss://default:<pass>@<host>:<port>
